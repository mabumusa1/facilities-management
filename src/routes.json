        { "path": ":categoryName/:id", "component": "ServiceCategory" },
        { "path": "ServiceDetails/:subCatId", "component": "ServiceDetails" },
        { "path": "AddNewSubcategory", "component": "AddNewSubcategory" },
        { "path": "EditSubcategory/:subCatId", "component": "EditSubcategory" },
        { "path": "selectCommunityBuilding", "component": "SelectCommunityBuilding" },
        { "path": ":subCategoryName/:subCatId", "component": "SubcategoryDetails" },
        { "path": ":typename/:typeId", "component": "TypeDetails" },
        { "path": "editType", "component": "EditType" },
        { "path": "newType", "component": "NewType" }
      ]
