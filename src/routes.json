    {
      "path": "/settings",
      "component": "Settings",
      "tabs": [
        "invoice",
        "service-request",
        "visitor-request",
        "bank-details",
        "visits-details",
        "sales-details"
      ],
      "children": [
        { "path": "invoice/", "component": "InvoiceSettings" },
        { "path": "service-request/", "component": "ServiceRequestSettings" },
        { "path": "service-request/:type/:catCode/:catId", "component": "ServiceRequestDetails" },
        { "path": "visitor-request", "component": "VisitorRequestSettings" },
        { "path": "bank-details", "component": "BankDetails" },
        { "path": "visits-details", "component": "VisitsDetails" },
        { "path": "sales-details", "component": "SalesDetails" },
        { "path": "addNewFacility/:facilityID?", "component": "AddFacility" },
        { "path": "facilities", "component": "Facilities" },
        { "path": "facility/:facilityID", "component": "FacilityDetails" },
        { "path": "forms/", "component": "Forms" },
        { "path": "forms/create", "component": "FormCreate" },
        { "path": "forms/select-community", "component": "FormSelectCommunity" },
        { "path": "forms/select-building", "component": "FormSelectBuilding" },
        { "path": "forms/preview/:id", "component": "FormPreview" }
