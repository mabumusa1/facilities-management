        "working_days": { "type": "hasMany", "model": "WorkingDay" },
        "featured": { "type": "hasMany", "model": "FeaturedService" },
        "selects": { "type": "morphMany", "model": "SelectableScope", "comment": "Scoped to buildings/communities" }
      }
    },
    "ServiceSetting": {
