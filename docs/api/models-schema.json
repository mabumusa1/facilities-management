        "has_sub_categories": { "type": "boolean", "nullable": false, "default": false, "cast": "string" },
        "icon_id": { "type": "integer", "nullable": true, "foreignKey": "media.id" }
      },
      "relationships": {
        "sub_categories": { "type": "hasMany", "model": "RequestSubcategory", "foreignKey": "category_id" },
