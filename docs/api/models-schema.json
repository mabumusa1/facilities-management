    "RequestSubcategory": {
      "table": "rf_request_subcategories",
      "endpoint": "rf/requests/sub-categories",
      "description": "Specific service types (Maintenance, Cleaning, Car Wash, etc.)",
      "properties": {
        "id": { "type": "integer", "nullable": false, "primary": true },
        "category_id": { "type": "integer", "nullable": false, "foreignKey": "rf_request_categories.id" },
        "name": { "type": "string", "nullable": false },
        "name_ar": { "type": "string", "nullable": true },
        "name_en": { "type": "string", "nullable": true },
        "status": { "type": "boolean", "nullable": false, "default": true, "cast": "string" },
        "icon_id": { "type": "integer", "nullable": true },
        "start": { "type": "time", "nullable": true },
        "end": { "type": "time", "nullable": true },
        "is_all_day": { "type": "boolean", "nullable": true },
        "terms_and_conditions": { "type": "text", "nullable": true }
      },
      "computed": {
