        "is_move_out": { "type": "boolean", "nullable": false, "default": false },
        "is_old": { "type": "boolean", "nullable": false, "default": false, "cast": "string" },
        "pdf_url": { "type": "string", "nullable": true },
        "created_at": { "type": "timestamp", "nullable": true },
        "updated_at": { "type": "timestamp", "nullable": true }
