      "computed": {
        "total_unpaid_amount": { "type": "decimal", "aggregate": "sum(transactions.left)" },
        "unpaid_transactions_count": { "type": "integer", "aggregate": "count(transactions where is_paid=false)" }
      },
      "relationships": {
        "tenant": { "type": "belongsTo", "model": "Tenant", "foreignKey": "tenant_id" },
        "status": { "type": "belongsTo", "model": "Status", "foreignKey": "status_id" },
        "lease_unit_type": { "type": "belongsTo", "model": "UnitCategory", "foreignKey": "lease_unit_type_id" },
        "rental_contract_type": { "type": "belongsTo", "model": "Setting", "foreignKey": "rental_contract_type_id" },
        "payment_schedule": { "type": "belongsTo", "model": "Setting", "foreignKey": "payment_schedule_id" },
        "units": { "type": "belongsToMany", "model": "Unit", "pivot": "lease_units", "pivotFields": ["rental_annual_type", "annual_rental_amount", "net_area", "meter_cost"] },
        "transactions": { "type": "hasMany", "model": "Transaction", "foreignKey": "lease_id" },
        "subleases": { "type": "hasMany", "model": "Lease", "foreignKey": "parent_lease_id" },
        "created_by": { "type": "belongsTo", "model": "User", "foreignKey": "created_by_id" },
        "deal_owner": { "type": "belongsTo", "model": "Admin", "foreignKey": "deal_owner_id" },
        "user": { "type": "belongsTo", "model": "Tenant", "foreignKey": "tenant_id", "alias": "user" },
        "additional_fees_lease": { "type": "hasMany", "model": "LeaseAdditionalFee" },
        "lease_escalations": { "type": "hasMany", "model": "LeaseEscalation" }
      },
      "validation": {
        "create": {
          "tenant": "required|array",
          "tenant.national_id": "required|string",
          "units": "required|array",
          "units.0.rental_amount": "required|numeric",
          "units.0.amount_type": "required|string",
          "rental_contract_type_id": "required|exists:rf_settings,id",
          "payment_schedule_id": "required|exists:rf_settings,id",
          "created_at": "required|date",
          "start_date": "required|date",
          "end_date": "required|date",
          "handover_date": "required|date",
          "lease_unit_type": "required|exists:rf_unit_categories,id",
          "tenant_type": "required|in:individual,company",
          "rental_type": "required|in:total,detailed",
          "autoGenerateLeaseNumber": "required|boolean"
        }
      }
    },
    "Transaction": {
      "table": "rf_transactions",
      "endpoint": "rf/transactions",
      "description": "Financial records (invoices, payments due)",
      "properties": {
        "id": { "type": "integer", "nullable": false, "primary": true },
        "lease_id": { "type": "integer", "nullable": true, "foreignKey": "rf_leases.id" },
        "unit_id": { "type": "integer", "nullable": true, "foreignKey": "rf_units.id" },
        "category_id": { "type": "integer", "nullable": false },
        "subcategory_id": { "type": "integer", "nullable": true },
        "type_id": { "type": "integer", "nullable": false },
        "status_id": { "type": "integer", "nullable": false },
        "assignee_id": { "type": "integer", "nullable": false, "comment": "Tenant/Owner ID" },
        "amount": { "type": "decimal", "nullable": false, "precision": 12, "scale": 2 },
        "tax_amount": { "type": "decimal", "nullable": false, "default": 0, "precision": 10, "scale": 2 },
        "rental_amount": { "type": "decimal", "nullable": true, "precision": 12, "scale": 2 },
        "additional_fees_amount": { "type": "decimal", "nullable": false, "default": 0, "precision": 10, "scale": 2 },
        "vat": { "type": "decimal", "nullable": false, "default": 0, "cast": "string" },
        "due_on": { "type": "date", "nullable": false },
        "details": { "type": "text", "nullable": true },
        "lease_number": { "type": "string", "nullable": true },
        "is_paid": { "type": "boolean", "nullable": false, "default": false },
        "is_old": { "type": "boolean", "nullable": false, "default": false, "cast": "string" },
        "created_at": { "type": "timestamp", "nullable": true },
        "updated_at": { "type": "timestamp", "nullable": true }
      },
      "computed": {
        "amount_fmt": { "type": "string", "format": "number_format(amount, 2)" },
        "paid_fmt": { "type": "string", "format": "number_format(payments_sum, 2)" },
        "left_fmt": { "type": "string", "format": "number_format(amount - payments_sum, 2)" },
        "paid": { "type": "decimal", "aggregate": "sum(payments.amount)" },
        "left": { "type": "decimal", "compute": "amount - paid" },
        "payments_sum": { "type": "decimal", "aggregate": "sum(payments.amount)" },
        "assignee": { "type": "string", "accessor": "assignee.name" },
        "assignee_active": { "type": "boolean", "accessor": "assignee.active" }
      },
      "relationships": {
        "lease": { "type": "belongsTo", "model": "Lease", "foreignKey": "lease_id" },
        "unit": { "type": "belongsTo", "model": "Unit", "foreignKey": "unit_id" },
        "category": { "type": "belongsTo", "model": "TransactionCategory", "foreignKey": "category_id" },
        "subcategory": { "type": "belongsTo", "model": "TransactionSubcategory", "foreignKey": "subcategory_id" },
        "type": { "type": "belongsTo", "model": "TransactionType", "foreignKey": "type_id" },
        "status": { "type": "belongsTo", "model": "TransactionStatus", "foreignKey": "status_id" },
        "payments": { "type": "hasMany", "model": "Payment", "foreignKey": "transaction_id" },
        "additional_fees": { "type": "hasMany", "model": "TransactionAdditionalFee" },
        "images": { "type": "morphMany", "model": "Media" }
      }
    },
    "RequestCategory": {
      "table": "rf_request_categories",
      "endpoint": "rf/requests/categories",
      "description": "Request categories (Home Services, Common Area, Visitor Access, Manager Requests)",
      "properties": {
