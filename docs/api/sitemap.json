{
  "site": "https://goatar.com",
  "apiBase": "https://api.goatar.com/api-management",
  "authentication": {
    "type": "Bearer Token",
    "headers": {
      "Authorization": "Bearer {token}",
      "X-Tenant": "{tenant_id}",
      "X-App-Locale": "en|ar"
    },
    "localStorage": {
      "token": "API authentication token",
      "X-Tenant": "Tenant identifier",
      "user": "User object with permissions and subscription info",
      "planFeatures": "Feature flags for subscription plan",
      "i18nextLng": "Language setting (en/ar)",
      "loggedIn": "Boolean login state",
      "plan": "Subscription plan ID"
    }
  },
  "pages": {
    "dashboard": {
      "path": "/dashboard",
      "title": "Dashboard",
      "description": "Main dashboard with units overview pie chart",
      "captured": true
    },
    "properties": {
      "path": "/properties-list/units",
      "title": "Properties",
      "description": "Property management",
      "subPages": [
        {"name": "Communities", "path": "/properties-list/units?tab=communities", "count": 1},
        {"name": "Buildings", "path": "/properties-list/units?tab=buildings", "count": 4},
        {"name": "Units", "path": "/properties-list/units?tab=units", "count": 3}
      ],
      "captured": true
    },
    "leasing": {
      "path": "/leasing/leases",
      "title": "Leasing",
      "description": "Lease management with statistics",
      "subPages": [
        {"name": "Visits", "path": "/leasing/visits"},
        {"name": "Applications", "path": "/leasing/applications"},
        {"name": "Quotes", "path": "/leasing/quotes"},
        {"name": "Leases", "path": "/leasing/leases"}
      ],
      "captured": true
    },
    "accounting": {
      "path": "/transactions",
      "title": "Accounting",
      "description": "Financial transactions management",
      "tabs": ["All", "Money In", "Money Out"],
      "captured": true
    },
    "contacts": {
      "path": "/contacts/Tenants",
      "title": "Contacts",
      "description": "Contact management",
      "subPages": [
        {"name": "Tenants", "path": "/contacts/Tenants"},
        {"name": "Owners", "path": "/contacts/Owners"},
        {"name": "Managers", "path": "/contacts/Managers"}
      ],
      "tabs": ["Individuals", "Companies"],
      "captured": true
    },
    "reporting": {
      "path": "/dashboard/system-reports",
      "title": "Reporting",
      "description": "System reports and analytics",
      "subPages": [
        {"name": "System Reports", "path": "/dashboard/system-reports"},
        {"name": "Power BI Reports", "path": "/dashboard/power-bi-reports"}
      ],
      "captured": true
    },
    "settings": {
      "path": "/settings",
      "title": "Settings",
      "description": "Application settings",
      "tabs": [
        {"tab": 0, "name": "Services Settings"},
        {"tab": 1, "name": "Lease Settings"},
        {"tab": 2, "name": "Visitor Settings"},
        {"tab": 3, "name": "Invoice Settings"},
        {"tab": 4, "name": "Offers Settings"},
        {"tab": 5, "name": "Facilities Settings"},
        {"tab": 6, "name": "Form Settings"},
        {"tab": 7, "name": "Company Profile"},
        {"tab": 8, "name": "Reset Account Data"},
        {"tab": 9, "name": "Directory Settings"}
      ],
      "captured": true
    }
  },
  "apiEndpoints": {
    "common": [
      "GET /notifications/unread-count",
      "GET /rf/modules",
      "GET /rf/users/requests/categories",
      "GET /rf/announcements"
    ],
    "dashboard": [
      "GET /reports/performance/units"
    ],
    "properties": [
      "GET /rf/communities",
      "GET /rf/buildings",
      "GET /rf/units"
    ],
    "leasing": [
      "GET /rf/leases",
      "GET /rf/leases/statistics"
    ],
    "accounting": [
      "GET /transactions",
      "GET /transactions-graph/all-transactions"
    ],
    "contacts": [
      "GET /rf/tenants",
      "GET /rf/owners",
      "GET /rf/managers",
      "GET /rf/contacts/statistics"
    ],
    "settings": [
      "GET /rf/company_profile",
      "GET /rf/requests/categories",
      "GET /countries"
    ]
  }
}
