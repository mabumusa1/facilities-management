{
  "endpoint": "marketplace/admin/settings/banks",
  "method": "GET",
  "schema": {
    "type": "object",
    "properties": {
      "data": {
        "type": "object",
        "nullable": false,
        "properties": {
          "beneficiary_name": {
            "type": "string",
            "nullable": false,
            "example": "Test Beneficiary"
          },
          "bank_name": {
            "type": "string",
            "nullable": false,
            "example": "Test Bank"
          },
          "account_number": {
            "type": "string",
            "nullable": false,
            "example": "12345678901234567890"
          },
          "iban": {
            "type": "string",
            "nullable": false,
            "example": "SA0380000000608010167519"
          }
        }
      },
      "success": {
        "type": "boolean",
        "nullable": false,
        "example": true
      },
      "message": {
        "type": "string",
        "nullable": false,
        "example": "تم استرجاع الاعدادات بنجاح"
      }
    },
    "meta": {
      "hasPagination": false
    }
  },
  "sample": {
    "beneficiary_name": "Test Beneficiary",
    "bank_name": "Test Bank",
    "account_number": "12345678901234567890",
    "iban": "SA0380000000608010167519"
  }
}